# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=Arionear RAG Agent
APP_VERSION=1.0.0

# LLM — OpenRouter
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Optional RAG
JINA_API_KEY=
PAGEINDEX_API_KEY=

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
DAILY_BUDGET_USD=5.0

# Storage (bắt buộc cho session stateless + rate limit + cost guard)
REDIS_URL=redis://localhost:6379/0

# Cloud deploy: BM25-only retrieval (no PyTorch). Local hybrid: false + requirements-local.txt
SKIP_LOCAL_EMBEDDINGS=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
